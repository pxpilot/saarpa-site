---
import { getCollection } from 'astro:content';
import WorkTemplate from '../../templates/Work.astro';

export async function getStaticPaths() {
    const entries = await getCollection('news');
    const sorted = entries.sort((a, b) =>
        new Date(b.data.date || 0).getTime() - new Date(a.data.date || 0).getTime()
    );

    return sorted.map((entry, index) => {
        const newer = index === 0 ? null : sorted[index - 1];
        const older = index === sorted.length - 1 ? null : sorted[index + 1];
        return {
            params: { slug: entry.slug },
            props: { entry, next: newer, prev: older },
        };
    });
}

const { entry, next, prev } = Astro.props;
---

<WorkTemplate entry={entry} next={next} prev={prev} baseSlug="blog" />
