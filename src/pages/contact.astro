---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Get in touch with Saar Paamoni.">
    <article class="post-content no-image">
        <div class="post-content-body contact-body">
            <h1 class="contact-title">Get in touch</h1>
            <p class="contact-lead">
                I read every message. If you're building something interesting,
                want to think through a hard problem together, or just want to say hi — reach out.
            </p>

            <!-- Replace YOUR_GOOGLE_FORM_EMBED_URL below with your Google Form embed src -->
            <!-- Go to Google Forms → Send → Embed (</>) → copy the src URL from the iframe code -->
            <div class="google-form-wrap">
                <iframe
                    src="https://docs.google.com/forms/d/e/1FAIpQLSdB9rshNCE2ZhiB67CrUguE5ZtEM0_Ctc23O_8wXq1LpOmLqw/viewform?embedded=true"
                    class="google-form"
                    frameborder="0"
                    marginheight="0"
                    marginwidth="0"
                    title="Contact form"
                >Loading…</iframe>
            </div>

            <p class="contact-alt">
                Or email me directly at
                <a href="mailto:saar@paamoni.com">saar@paamoni.com</a>
            </p>
        </div>
    </article>
</Layout>

<style>
.contact-body {
    max-width: 640px;
    margin: 0 auto;
    padding: 4rem var(--margin);
}

.contact-title {
    font-family: var(--font-sans-serif);
    font-variant: small-caps;
    font-weight: var(--font-light);
    font-size: 4rem;
    letter-spacing: 0.05em;
    color: var(--color-base);
    margin: 0 0 1rem;
}

.contact-lead {
    font-family: var(--font-serif);
    font-size: 1.9rem;
    line-height: 1.65;
    color: var(--color-base);
    opacity: 0.8;
    margin: 0 0 3rem;
}

.google-form-wrap {
    width: 100%;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
}

.google-form {
    width: 100%;
    height: 860px;
    border: none;
    display: block;
}

.contact-alt {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: var(--color-base);
    opacity: 0.6;
    margin-top: 2rem;
}

.contact-alt a {
    color: var(--color-primary);
    text-decoration: none;
}

.contact-alt a:hover {
    text-decoration: underline;
}
</style>
