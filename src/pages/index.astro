---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Saar Paamoni" description="Product advisor, artist, builder." backgroundVideo="/video/home.mov">
    <div class="home-hero">
        <div class="hero-inner">
            <p class="hero-label">Saar Paamoni</p>
            <h1 class="hero-headline">
                Product builder.<br />Artist. Surfer.
            </h1>
            <p class="hero-sub">
                I help founders figure out what to build, and why it matters.
            </p>
            <div class="hero-ctas">
                <a href="/consulting" class="btn btn-primary">Work with me</a>
                <a href="/art" class="btn btn-secondary">View my art</a>
            </div>
        </div>
    </div>

    <section class="home-section">
        <div class="home-section-inner">
            <div class="home-card">
                <span class="home-card-label">Currently building</span>
                <p class="home-card-text">
                    Something at the intersection of AI and media measurement.
                    The old ways of tracking attention are breaking — I'm working
                    on what comes next.
                </p>
                <a href="/consulting" class="home-card-link">Learn more →</a>
            </div>
            <div class="home-card">
                <span class="home-card-label">Art</span>
                <p class="home-card-text">
                    Acrylic on canvas. Bold marks, warm palettes, textures
                    that took time. This is how I think without words.
                </p>
                <a href="/art" class="home-card-link">View gallery →</a>
            </div>
        </div>
    </section>
</Layout>

<style>
/* ── Hero ── */
.home-hero {
    display: flex;
    align-items: flex-start;
    padding: 4rem var(--margin) 2rem;
}

.hero-inner {
    max-width: 680px;
}

.hero-label {
    font-family: var(--font-sans-serif);
    font-size: 1.1rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 0.35rem;
}

.hero-headline {
    font-family: var(--font-sans-serif);
    font-weight: 300;
    font-size: clamp(3.5rem, 7vw, 7rem);
    line-height: 1.05;
    letter-spacing: 0.01em;
    color: var(--color-base);
    margin: 0 0 0.5rem;
}

.hero-sub {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 2vw, 2rem);
    line-height: 1.65;
    color: var(--color-base);
    opacity: 0.75;
    max-width: 480px;
    margin: 0 0 3rem;
}

.hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
}

.btn {
    display: inline-block;
    padding: 0.8rem 2rem;
    font-family: var(--font-sans-serif);
    font-size: 1.4rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: var(--radius);
    transition: all 0.2s ease;
}

.btn-primary {
    background: var(--color-primary);
    color: #FFF8F1;
}

.btn-primary:hover {
    background: var(--color-base);
    color: var(--color-bg);
}

.btn-secondary {
    background: transparent;
    color: var(--color-base);
    border: 1px solid var(--color-border);
}

.btn-secondary:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
}

/* ── Cards ── */
.home-section {
    padding: 2rem var(--margin) 6rem;
    border-top: 1px solid var(--color-border);
    backdrop-filter: blur(2px);
    background: rgba(255, 248, 241, 0.6);
    margin-top: 50px;
}

[data-theme="dark"] .home-section {
    background: rgba(26, 18, 16, 0.6);
}

.home-section-inner {
    max-width: 900px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2rem;
}

.home-card {
    padding: 2rem 0;
    border-top: 2px solid var(--color-primary);
}

.home-card-label {
    display: block;
    font-family: var(--font-sans-serif);
    font-size: 1.2rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
}

.home-card-text {
    font-family: var(--font-serif);
    font-size: 1.9rem;
    line-height: 1.75;
    color: var(--color-base);
    margin: 0 0 1rem;
}

.home-card-link {
    font-family: var(--font-sans-serif);
    font-size: 1.4rem;
    color: var(--color-primary);
    text-decoration: none;
    letter-spacing: 0.05em;
}

.home-card-link:hover {
    text-decoration: underline;
}

/* ── Mobile ── */
@media (max-width: 600px) {
    .home-hero {
        min-height: 70vh;
        padding: 4rem var(--margin);
    }
}
</style>
