---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Saar Paamoni" description="Product advisor, artist, builder.">
    <div class="home-hero">
        <div class="hero-image-wrap">
            <img src="/img/homepage-me2.png" alt="Saar Paamoni" class="hero-img" />
            <div class="hero-overlay">
                <p class="hero-text">
                    <span>Hey, I'm Saar – a dad, creator, artist,</span>
                    <span>and surfer with a passion for</span>
                    <span>art, tech, and music.</span>
                    <span class="hero-spacer"></span>
                    <span>As a value-driven Product Manager,</span>
                    <span>I bring creativity and purpose to</span>
                    <span>everything I do.</span>
                </p>
            </div>
        </div>
        <div class="home-ctas">
            <a href="/consulting" class="btn btn-primary">Work with me</a>
            <a href="/art" class="btn btn-secondary">View my art</a>
        </div>
    </div>

    <section class="home-section">
        <div class="home-section-inner">
            <div class="home-card">
                <span class="home-card-label">Currently building</span>
                <p class="home-card-text">
                    Exploring how AI is reshaping the relationship between attention,
                    reach, and impact across media. Stealth for now.
                </p>
                <a href="/consulting" class="home-card-link">Learn more →</a>
            </div>
            <div class="home-card">
                <span class="home-card-label">Art</span>
                <p class="home-card-text">
                    Acrylic on canvas. Painting is how I think without language —
                    bold strokes, warm palettes, textures that take time.
                </p>
                <a href="/art" class="home-card-link">View gallery →</a>
            </div>
            <div class="home-card">
                <span class="home-card-label">Writing</span>
                <p class="home-card-text">
                    Notes on product, AI, media, and what I'm figuring out
                    in public.
                </p>
                <a href="/blog" class="home-card-link">Read posts →</a>
            </div>
        </div>
    </section>
</Layout>

<style>
.home-hero {
    display: flex;
    flex-direction: column;
}

/* ── Triptych image — break out of site-wrapper padding ── */
.hero-image-wrap {
    position: relative;
    width: calc(100% + 6vw);
    margin-left: -3vw;
    margin-right: -3vw;
    line-height: 0;
}

@media (max-width: 850px) {
    .hero-image-wrap {
        width: calc(100% + 12vw);
        margin-left: -6vw;
        margin-right: -6vw;
    }
}

.hero-img {
    width: 100%;
    height: 26.5vw;
    display: block;
    object-fit: cover;
}

/* ── Text overlay ── */
.hero-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 4%;
    pointer-events: none;
}

.hero-text {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin: 0;
}

.hero-text span {
    display: inline;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.4rem, 2.8vw, 2.8rem);
    line-height: 1.75;
    color: #1a1210;
    background: rgba(255, 248, 241, 0.88);
    padding: 0.1em 0.45em;
    -webkit-box-decoration-break: clone;
    box-decoration-break: clone;
    margin-bottom: 0.2em;
    width: fit-content;
}

.hero-spacer {
    display: block !important;
    background: transparent !important;
    height: 0.6em;
    padding: 0 !important;
    margin-bottom: 0 !important;
}

.home-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 2.5rem var(--margin) 0;
}

.btn {
    display: inline-block;
    padding: 0.8rem 2rem;
    font-family: var(--font-sans-serif);
    font-size: 1.4rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: var(--radius);
    transition: all 0.2s ease;
}

.btn-primary {
    background: var(--color-primary);
    color: #FFF8F1;
}

.btn-primary:hover {
    background: var(--color-base);
    color: var(--color-bg);
}

.btn-secondary {
    background: transparent;
    color: var(--color-base);
    border: 1px solid var(--color-border);
}

.btn-secondary:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
}

.home-section {
    padding: 2rem var(--margin) 6rem;
    border-top: 1px solid var(--color-border);
}

.home-section-inner {
    max-width: 900px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2rem;
}

.home-card {
    padding: 2rem 0;
    border-top: 2px solid var(--color-primary);
}

.home-card-label {
    display: block;
    font-family: var(--font-sans-serif);
    font-size: 1.2rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
}

.home-card-text {
    font-family: var(--font-serif);
    font-size: 1.7rem;
    line-height: 1.6;
    color: var(--color-base);
    margin: 0 0 1rem;
}

.home-card-link {
    font-family: var(--font-sans-serif);
    font-size: 1.4rem;
    color: var(--color-primary);
    text-decoration: none;
    letter-spacing: 0.05em;
}

.home-card-link:hover {
    text-decoration: underline;
}
</style>
