---
import Layout from '../layouts/Layout.astro';
import ConsultingCard from '../components/ConsultingCard.astro';
---

<Layout
    title="Consulting"
    description="Product &amp; Strategy Advisor — Saar Paamoni. 10 years building measurement infrastructure at scale."
>
    <!-- Hero -->
    <section class="consulting-hero">
        <div class="consulting-hero-inner">
            <p class="consulting-label">Advisory &amp; Consulting</p>
            <h1 class="consulting-headline">Product &amp; Strategy Advisor</h1>
            <p class="consulting-sub">
                I spent a decade inside one of adtech's hardest measurement problems.
                Now I help founders avoid the mistakes I watched everyone else make.
            </p>
            <a href="/contact" class="consulting-cta">Let's Talk →</a>
        </div>
    </section>

    <!-- Services grid -->
    <section class="consulting-services">
        <div class="consulting-section-inner">
            <h2 class="consulting-section-title">How I help</h2>
            <div class="consulting-grid">
                <ConsultingCard
                    title="Product Strategy"
                    body="Turn ambiguity into a roadmap. I help teams cut through the noise and bet on the right things — before the window closes."
                />
                <ConsultingCard
                    title="CTV &amp; AI Advisory"
                    body="10 years inside the measurement stack at scale. I like thinking about the hard problems and identify the real opportunities in AI-native media and emerging channels."
                />
                <ConsultingCard
                    title="Growth &amp; GTM"
                    body="Get specific about who you're for, how you'll reach them, and what makes the first 100 customers want to tell someone."
                />
                <ConsultingCard
                    title="Fundraising &amp; Narrative"
                    body="A sharp 'why now' is worth more than a polished deck. I help founders find the story before they try to sell it."
                />
            </div>
        </div>
    </section>

    <!-- Background -->
    <section class="consulting-background">
        <div class="consulting-section-inner consulting-prose">
            <h2 class="consulting-section-title">Background</h2>
            <p>
                Spent a decade as SVP Product at DoubleVerify, where I led measurement
                and verification products across CTV, display, video, and mobile — at a
                scale of billions of signals per day. I've worked across the full ad
                ecosystem: DSPs, SSPs, publishers, agencies, and standards bodies.
            </p>
        </div>
    </section>

    <!-- Currently Building (stealth) -->
    <section class="consulting-stealth">
        <div class="consulting-section-inner consulting-prose">
            <h2 class="consulting-section-title">Currently building</h2>
            <p class="consulting-stealth-copy">
                I'm in the early stages of building something new — exploring how AI is
                reshaping the relationship between attention, reach, and impact across media.
                Details are stealth for now, but the space sits at the intersection of AI and
                the future of how brands and publishers understand real audience engagement.
                More soon.
            </p>
        </div>
    </section>

    <!-- CTA -->
    <section class="consulting-contact">
        <div class="consulting-section-inner">
            <p class="consulting-contact-text">
                Whether you're building something new or navigating something complex —
            </p>
            <a href="/contact" class="consulting-cta consulting-cta-large">Get in touch →</a>
        </div>
    </section>
</Layout>

<style>
/* Hero */
.consulting-hero {
    display: flex;
    align-items: center;
    padding: 3rem var(--margin) 2rem;
    border-bottom: 1px solid var(--color-border);
}

.consulting-hero-inner {
    max-width: 700px;
    margin: 0 auto;
    width: 100%;
}

.consulting-label {
    font-family: var(--font-sans-serif);
    font-size: 1.2rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 1rem;
}

.consulting-headline {
    font-family: var(--font-sans-serif);
    font-variant: small-caps;
    font-weight: var(--font-light);
    font-size: clamp(2.8rem, 6vw, 5.5rem);
    letter-spacing: 0.04em;
    color: var(--color-base);
    margin: 0 0 1rem;
    line-height: 1.05;
}

.consulting-sub {
    font-family: var(--font-serif);
    font-size: 2rem;
    line-height: 1.65;
    color: var(--color-base);
    opacity: 0.8;
    max-width: 560px;
    margin: 0 0 2rem;
}

.consulting-cta {
    display: inline-block;
    padding: 0.85rem 2.2rem;
    background: var(--color-primary);
    color: #FFF8F1;
    text-decoration: none;
    font-family: var(--font-sans-serif);
    font-size: 1.4rem;
    letter-spacing: 0.08em;
    border-radius: var(--radius);
    transition: background 0.2s ease;
}

.consulting-cta:hover {
    background: var(--color-base);
}

/* Sections */
.consulting-services,
.consulting-background,
.consulting-stealth,
.consulting-contact {
    padding: 4rem var(--margin);
    border-bottom: 1px solid var(--color-border);
}

.consulting-section-inner {
    max-width: 760px;
    margin: 0 auto;
}

.consulting-section-title {
    font-family: var(--font-sans-serif);
    font-variant: small-caps;
    font-weight: var(--font-normal);
    font-size: 1.35rem;
    letter-spacing: 0.2em;
    text-transform: lowercase;
    color: var(--color-primary);
    margin: 0 0 2rem;
}

/* Services grid */
.consulting-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
}

/* Prose sections */
.consulting-prose p {
    font-family: var(--font-serif);
    font-size: 1.8rem;
    line-height: 1.8;
    color: var(--color-base);
    margin: 0;
}

/* Stealth copy */
.consulting-stealth {
    background: var(--color-bg);
    position: relative;
}

.consulting-stealth::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--color-primary);
    opacity: 0.3;
}

.consulting-stealth-copy {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.9rem;
    line-height: 1.8;
    color: var(--color-base);
    opacity: 0.9;
    margin: 0;
}

/* Bottom CTA */
.consulting-contact {
    text-align: center;
    border-bottom: none;
    padding: 5rem var(--margin);
}

.consulting-contact-text {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.9rem;
    color: var(--color-base);
    opacity: 0.7;
    margin: 0 0 1.5rem;
}

.consulting-cta-large {
    font-size: 1.6rem;
    padding: 1rem 2.5rem;
}
</style>
